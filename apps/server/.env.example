# Postgres. Локально: DB URL из `bunx supabase start`.
# Прод: Supavisor transaction pooler :6543 требует PG_PREPARE=false (findings D12).
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Supabase API (для T7+)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your-anon-key

# Верификация JWT (jose): JWKS = {SUPABASE_URL}/auth/v1/.well-known/jwks.json,
# fallback HS256 по legacy-секрету (локально — JWT_SECRET из `bunx supabase status`)
SUPABASE_JWT_SECRET=your-jwt-secret
# SUPABASE_JWKS_URL=  # опциональный override URL JWKS

# Отключить prepared statements (обязательно для пулера :6543)
# PG_PREPARE=false
