# Продуктовое подключение (роль orbis_app, RLS enforced). Локально:
DATABASE_URL=postgres://orbis_app:orbis_app_local@127.0.0.1:54322/postgres
# Админ (миграции, setup-db, сид реестра). НЕ используется продуктовым кодом:
DATABASE_URL_ADMIN=postgres://postgres:postgres@127.0.0.1:54322/postgres
ORBIS_APP_PASSWORD=orbis_app_local
# prepare=false обязателен только для transaction-пулера :6543 (hosted)
# PG_PREPARE=false

# Supabase API (для T7+)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your-anon-key

# Верификация JWT (jose): JWKS = {SUPABASE_URL}/auth/v1/.well-known/jwks.json,
# fallback HS256 по legacy-секрету (локально — JWT_SECRET из `bunx supabase status`)
SUPABASE_JWT_SECRET=your-jwt-secret
# SUPABASE_JWKS_URL=  # опциональный override URL JWKS

# PAT внешних агентов (§9.3, MCP): hash-only — сервер хранит только sha256 токена,
# сырой токен показывается один раз при выдаче. Выдача: bun scripts/issue-pat.ts
# (печатает токен + готовую строку ORBIS_PAT_HASH). Отзыв = смена значения + рестарт.
# ORBIS_PAT_HASH=
# ORBIS_PAT_OWNER_ID=
