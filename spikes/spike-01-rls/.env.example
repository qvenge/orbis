# Подключения к БД. APP — рабочая роль спайка (без BYPASSRLS), ADMIN — только setup-db/контрольные тесты.
DATABASE_URL_APP=postgresql://orbis_app:spike-local-password@127.0.0.1:54322/postgres
DATABASE_URL_ADMIN=postgresql://postgres:postgres@127.0.0.1:54322/postgres
ORBIS_APP_PASSWORD=spike-local-password

# prepare=false обязателен для transaction-пулера Supavisor (порт 6543)
PG_PREPARE=true

# Механика identity: claims (основная, auth.uid) | app_setting (fallback, current_setting('app.user_id'))
IDENTITY_MODE=claims

# Supabase (для jwt.test.ts): значения из вывода `bunx supabase start` / dashboard hosted-проекта
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
